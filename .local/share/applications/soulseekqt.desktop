[Desktop Entry]
Name=SoulSeek
GenericName=P2P file-sharing network
Exec=systemd-run --user --scope --unit=soulseek -p CPUQuota=33% /usr/bin/soulseekqt
# Exec=soulseekqt
Icon=soulseek
Terminal=false
Type=Application
Categories=Network;P2P;
Comment=Soulseek music-sharing client
StartupWMClass=soulseekqt.AppImage
