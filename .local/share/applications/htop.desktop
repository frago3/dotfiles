[Desktop Entry]
Type=Application
Version=1.0
Name=Htop
GenericName=Process Viewer
Comment=Show System Processes
Icon=htop
# Exec=htop
Exec=xterm -fa monospace:size=10 -class Htop -e htop
# Exec=xterm -fa monospace:size=10 -class Htop -title htop -e 'TERM=xterm-256color htop'
Terminal=false
Categories=System;Monitor;ConsoleOnly;
Keywords=system;process;task
