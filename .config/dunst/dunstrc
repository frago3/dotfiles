# See dunst(5) for all configuration options

[global]
    ### Geometry ###
    width = (0, 900)
    height = 900
    origin = top-left
    offset = 10x12

    notification_limit = 6
    show_age_threshold = -1


    progress_bar = false
    separator_height = 0
    padding = 4
    frame_width = 0

    ### Text ###
    markup = full

    # The format of the message.  Possible variables are:
    #   %a  appname
    #   %s  summary
    #   %b  body
    #   %i  iconname (including its path)
    #   %I  iconname (without its path)
    #   %p  progress value if set ([  0%] to [100%]) or nothing
    #   %n  progress value if set without any extra characters
    #   %%  Literal %
    font = "System-ui Bold 10"
    format = "%s<tt>%b</tt>"
    # format = "%s<span font="monospace bold 10">%b</span>"
    # format = "%s<span font="monospace 10">%b</span>"
    # format = "%s%b"
    icon_position = off

    ### mouse
    mouse_left_click = close_current
    mouse_middle_click = close_current
    mouse_right_click = close_current

[urgency_low]
    foreground = "#deddda"
    background = "#000000"
    timeout = 1

[urgency_critical]
    # foreground = "#f6f5f4"
    foreground = "#000000"
    background = "#c01c28"
    timeout = 0

[urgency_normal]
    foreground = "#deddda"
    background = "#000000"
    timeout = 0

# vim: ft=cfg
