[options]
suppress_default_binds = true
height = 1060
scaling_mode = shrink

[binds]
q            = quit
<Escape>     = quit
y            = exec echo working!

<Left>       = prev
<Right>      = next
gg           = goto 1
<Shift+G>    = goto -1

<Ctrl+Down>  = pan 0 -50
<Ctrl+Up>    = pan 0 50
<Ctrl+Left>  = pan 50 0
<Ctrl+Right> = pan -50 0

# Zooming
<Up>         = zoom 2
<Down>       = zoom -2
<Shift+Up>   = zoom 1
<Shift+Down> = zoom -1

# Rotate Clockwise by 90 degrees
<Ctrl+r>        = rotate by 90

# Other commands
x               = close
f               = fullscreen
<Return>        = fullscreen
p               = exec echo $imv_current_file
c               = center
s               = scaling next
<Shift+S>       = upscaling next
a               = zoom actual
r               = reset

# Gif playback
<period>        = next_frame
<space>         = toggle_playing

# Slideshow control
t               = slideshow +1
<Shift+T>       = slideshow -1
