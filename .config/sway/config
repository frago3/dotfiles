### Output configuration
output eDP-1 resolution 1920x1080 position 0,0 scale 1
# output eDP-1 bg #0A3B76 solid_color

### Input configuration
input type:keyboard {
  xkb_layout      latam
}
input type:touchpad {
  dwt             disabled
  tap             enabled
  natural_scroll  enabled
}

###
xwayland disable
default_border          pixel 1
default_floating_border pixel 1

# floating_maximum_size 1920 x 1080
floating_maximum_size 1920 x 1062
for_window [app_id="wev|imv|mpv|zathura"] floating enable
for_window [title="(?:Open|Save) (?:File|Folder|As)"] floating enable
for_window [title="Picture-in-Picture|File Operation Operation Progress"] floating enable

## Theme
set $base #000000
set $text #deddda
set $txt1 #5e5c64
set $urgt #f66151

# target                 brder bg    text 
client.focused           $base $base $base
client.focused_inactive  $base $base $base
client.unfocused         $base $base $base

# Status Bar:
bar {
  position          top
  height            18
  status_padding    0
  font              pango:System-ui Bold 10

  status_command /usr/bin/i3status-rs ~/.config/sway/status.toml

  colors {
    statusline          $text
    # background          $base
    focused_workspace   $base $base $text
    inactive_workspace  $base $base $txt1
    binding_mode        $base $base $text
    urgent_workspace    $base $base $urgt
  }
}

include ~/.config/sway/config.d/*
