### Output configuration
output eDP-1 resolution 1920x1080 position 0,0
output eDP-1 bg #0A3B76 solid_color
### Input configuration
input "1:1:AT_Translated_Set_2_keyboard" {
    xkb_layout latam
}
input type:touchpad {
    dwt disabled
    tap enabled
    natural_scroll enabled
}

### Variables
default_border          pixel 1
default_floating_border pixel 1
xwayland disable

floating_maximum_size 1920 x 1062

for_window [app_id="wev|imv|mpv|zathura|mousepad"] floating enable
for_window [app_id="foof"] floating enable, resize set 1215 920

# Basics:
    bindsym Mod4+Shift+Return   exec foot tmux
    bindsym Mod4+Return         exec foot
    # bindsym Mod4+Shift+Return   exec foot
    # bindsym Mod4+Return         exec footclient
    bindsym Mod4+w              exec firefox
    bindsym Mod4+Shift+w        exec firefox --private-window
    bindsym Mod4+e              exec thunar
    bindsym Mod4+Print          exec grim -co eDP-1

    # Kill focused window
    bindsym Ctrl+Shift+q kill

    floating_modifier Mod4 normal

    # Reload the configuration file
    bindsym Mod4+Shift+r reload

    bindsym XF86AudioRaiseVolume   exec ~/.local/bin/mkeys_volume.sh -up
    bindsym XF86AudioLowerVolume   exec ~/.local/bin/mkeys_volume.sh -down
    bindsym XF86AudioMute          exec ~/.local/bin/mkeys_volume.sh -mute
    bindsym XF86MonBrightnessUp    exec ~/.local/bin/mkeys_light.sh -up
    bindsym XF86MonBrightnessDown  exec ~/.local/bin/mkeys_light.sh -down


# Moving around:
    bindsym Mod4+Left   focus left
    bindsym Mod4+Down   focus down
    bindsym Mod4+Up     focus up
    bindsym Mod4+Right  focus right

# Workspaces:
    bindsym Mod4+1 workspace number 1
    bindsym Mod4+2 workspace number 2
    bindsym Mod4+3 workspace number 3
    bindsym Mod4+4 workspace number 4
    bindsym Mod4+5 workspace number 5
    bindsym Mod4+6 workspace number 6
    bindsym Mod4+7 workspace number 7
    bindsym Mod4+8 workspace number 8
    bindsym Mod4+9 workspace number 9
    bindsym Mod4+0 workspace number 10

    bindsym Mod4+Shift+1 move container to workspace number 1
    bindsym Mod4+Shift+2 move container to workspace number 2
    bindsym Mod4+Shift+3 move container to workspace number 3
    bindsym Mod4+Shift+4 move container to workspace number 4
    bindsym Mod4+Shift+5 move container to workspace number 5
    bindsym Mod4+Shift+6 move container to workspace number 6
    bindsym Mod4+Shift+7 move container to workspace number 7
    bindsym Mod4+Shift+8 move container to workspace number 8
    bindsym Mod4+Shift+9 move container to workspace number 9
    bindsym Mod4+Shift+0 move container to workspace number 10

# Move
    set $range 119px
    bindsym Mod4+Shift+Escape    move position center
    bindsym Mod4+Shift+kp_home   move absolute position 0 px 18 px
    bindsym Mod4+Shift+kp_end    exec ~/.config/sway/scripts/sway_move.sh -bottomleft
    bindsym Mod4+Shift+kp_prior  exec ~/.config/sway/scripts/sway_move.sh -topright
    bindsym Mod4+Shift+kp_next   exec ~/.config/sway/scripts/sway_move.sh -bottomright
    bindsym Mod4+Shift+Left      move left  $range
    bindsym Mod4+Shift+Down      move down  $range
    bindsym Mod4+Shift+Up        move up    $range
    bindsym Mod4+Shift+Right     move right $range

# Resize
    bindsym Alt+Shift+Up         resize shrink   height  $range
    bindsym Alt+Shift+Left       resize shrink   width   $range
    bindsym Alt+Shift+Down       resize grow     height  $range
    bindsym Alt+Shift+Right      resize grow     width   $range

# Layout stuff:
    bindsym Mod4+space          exec ~/.config/sway/scripts/bemenu_run.sh
    bindsym Mod4+plus           focus parent
    bindsym Mod4+braceright     focus child
    bindsym Mod4+braceleft      layout toggle split
    bindsym Mod4+Escape         focus mode_toggle
    bindsym Mod4+kp_end         exec ~/.config/sway/scripts/sway_floatingtoggle.sh
    bindsym Mod4+kp_prior       split toggle
    bindsym Mod4+kp_next        split none
    bindsym Ctrl+Alt+up         exec ~/.config/sway/scripts/bemenu_windows.sh
    bindsym Ctrl+Alt+down       exec ~/.config/sway/scripts/bemenu_find.sh
    bindsym Ctrl+Alt+kp_next    exec ~/.config/sway/scripts/sway_newworkspace.sh
    bindsym Ctrl+Alt+right      workspace next
    bindsym Ctrl+Alt+left       workspace prev

    bindgesture swipe:3:left    workspace next
    bindgesture swipe:3:right   workspace prev
    bindgesture swipe:3:up      exec ~/.config/sway/scripts/sway_focuslast.sh
    bindgesture swipe:3:down    scratchpad show

# Scratchpad:
    bindsym Alt+s                exec ~/.config/sway/scripts/sway_movescratchpad.sh
    bindsym Alt+Tab              scratchpad show

mode "status" {
    bindsym w exec ~/.local/bin/status_wifi.sh,               mode "default"
    bindsym p exec ~/.local/bin/status_ps.sh,                 mode "default"
    bindsym f exec ~/.local/bin/status_fetch.sh,              mode "default"
    bindsym c exec ~/.local/bin/status_calendar.sh,           mode "default"
    bindsym h exec foot -f 'monospace:size=10' -T htop htop,  mode "default"
    bindsym Escape mode "default"
}
bindsym Mod4+p mode "status"
bindsym Mod4+backspace exec dunstctl close

set $base #000000
set $text #c0bfbc
set $txt1 #5e5c64
set $urgt #f66151

# target                 border bg    text 
client.focused           $base  $base $text
client.focused_inactive  $base  $base $txt1
client.unfocused         $base  $base $txt1

# Status Bar:
bar {
    position top
    font "System-ui Bold 10"
    height 18
    status_command /usr/bin/i3status-rs ~/.config/sway/status.toml

    colors {
        statusline          $text
        background          $base
        focused_workspace   $base $base $text
        inactive_workspace  $base $base $txt1
        urgent_workspace    $base $base $urgt
        binding_mode        $base $base $text
    }
}

include ~/.config/sway/config.d/*
